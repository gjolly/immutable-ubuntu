#!/bin/sh
# initramfs-tools hook — copies veritysetup and dm-verity module into the initramfs.

PREREQ=""
prereqs() { echo "$PREREQ"; }
case $1 in
  prereqs) prereqs; exit 0 ;;
esac

. /usr/share/initramfs-tools/hook-functions

# Copy veritysetup binary (location differs across Ubuntu releases).
for bin in /sbin/veritysetup /usr/sbin/veritysetup; do
    if [ -x "$bin" ]; then
        copy_exec "$bin" /sbin/veritysetup
        break
    fi
done

# Ensure the dm-verity kernel module and its dependencies are present.
manual_add_modules dm-verity
