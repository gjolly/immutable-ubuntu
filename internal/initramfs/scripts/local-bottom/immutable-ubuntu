#!/bin/sh
# initramfs-tools local-bottom script — mounts per-directory writable overlays when
# immutable-ubuntu.overlay=<dirs> is present on the kernel command line.
#
# This runs after the root is mounted at $rootmnt but before switch_root.
# Each listed directory (e.g. "var,etc") gets its own overlayfs mount backed by a
# shared tmpfs, leaving the rest of the verity root truly read-only.
#
# systemd's systemd-volatile-root.service only works inside a systemd-based initrd,
# which Ubuntu's busybox initramfs is not, so we handle this ourselves.

PREREQ=""
prereqs() { echo "$PREREQ"; }
case $1 in
  prereqs) prereqs; exit 0 ;;
esac

. /scripts/functions

# Parse immutable-ubuntu.overlay=var,etc from the kernel command line.
OVERLAY_DIRS=""
for x in $(cat /proc/cmdline); do
    case "$x" in
        immutable-ubuntu.overlay=*) OVERLAY_DIRS="${x#immutable-ubuntu.overlay=}" ;;
    esac
done

[ -n "$OVERLAY_DIRS" ] || exit 0

log_begin_msg "immutable-ubuntu: setting up volatile overlay(s) on root"

# Create a single tmpfs to back all overlay upper and work directories.
# The overlay filesystem holds kernel-level references to this tmpfs, so it stays
# alive even after the initramfs is torn down by switch_root.
mkdir -p /run/volatile-upper
if ! mount -t tmpfs volatile-upper /run/volatile-upper; then
    log_failure_msg "immutable-ubuntu: failed to mount tmpfs for volatile overlay"
    exit 1
fi

# Mount a per-directory overlay for each directory in the comma-separated list.
IFS=','
for dir in $OVERLAY_DIRS; do
    mkdir -p "/run/volatile-upper/upper/${dir}" "/run/volatile-upper/work/${dir}"
    if ! mount -t overlay overlay \
        -o "lowerdir=${rootmnt}/${dir},upperdir=/run/volatile-upper/upper/${dir},workdir=/run/volatile-upper/work/${dir}" \
        "${rootmnt}/${dir}"; then
        log_failure_msg "immutable-ubuntu: failed to mount volatile overlay on /${dir}"
        umount /run/volatile-upper
        exit 1
    fi
done

log_end_msg
