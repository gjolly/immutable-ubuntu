#!/bin/sh
# initramfs-tools local-premount script — sets up dm-verity before the root is mounted.

PREREQ=""
prereqs() { echo "$PREREQ"; }
case $1 in
  prereqs) prereqs; exit 0 ;;
esac

. /scripts/functions

ROOTHASH=""
ROOTDATA_DEV=""
ROOTHASH_DEV=""

for x in $(cat /proc/cmdline); do
    case "$x" in
        roothash=*)   ROOTHASH="${x#roothash=}" ;;
        root_data_dev=PARTUUID=*) ROOTDATA_DEV="$(findfs "PARTUUID=${x#root_data_dev=PARTUUID=}" 2>/dev/null)" ;;
        root_data_dev=/dev/*)  ROOTDATA_DEV="${x#root_data_dev=}" ;;
        root_hash_dev=PARTUUID=*) ROOTHASH_DEV="$(findfs "PARTUUID=${x#root_hash_dev=PARTUUID=}" 2>/dev/null)" ;;
        root_hash_dev=/dev/*)  ROOTHASH_DEV="${x#root_hash_dev=}" ;;
    esac
done

# Nothing to do if no root hash was specified.
[ -n "$ROOTHASH" ] || exit 0

if [ -z "$ROOTDATA_DEV" ]; then
    panic "immutable-ubuntu: cannot determine verity root data device from cmdline"
fi

if [ -z "$ROOTHASH_DEV" ]; then
    panic "immutable-ubuntu: cannot determine verity root hash device from cmdline"
fi

log_begin_msg "immutable-ubuntu: opening dm-verity root on $ROOTDATA_DEV"
veritysetup open "$ROOTDATA_DEV" root "$ROOTHASH_DEV" "$ROOTHASH"
log_end_msg

# Replace the root device with the mapped verity device.
ROOT=/dev/mapper/root
